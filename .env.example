# Copy this file to `.env` and fill in your free API keys.
# `.env` is gitignored — never commit real keys.

# U.S. Census Bureau API key — request at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_key_here

# NREL / DOE Alternative Fuels Data Center (AFDC) — request at https://developer.nrel.gov/signup/
NREL_API_KEY=your_nrel_key_here

# transit.land API key (Interline) — request at https://www.transit.land/documentation
TRANSITLAND_API_KEY=your_transitland_key_here

# Mobility Database refresh token — for operators without a key-free GTFS feed
# (e.g. METRO Houston). Free token at https://mobilitydatabase.org
MOBILITYDB_REFRESH_TOKEN=your_mobilitydb_refresh_token_here
